{
  "name": "@trk/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas.d.ts",
      "import": "./dist/schemas.js"
    },
    "./trk": {
      "types": "./dist/trk.d.ts",
      "import": "./dist/trk.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/schemas.ts src/trk.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts src/schemas.ts src/trk.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
